# .env.example
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.
#
# Used in Exercise 03 when you patch Bug #8 (weak JWT secret).
# After patching src/auth.js to read from process.env.JWT_SECRET,
# generate a strong secret and paste it here:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#

JWT_SECRET=replace_this_with_a_64_character_random_hex_string

# Server config (optional)
PORT=3000
